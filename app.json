{
  "expo": {
    "name": "CoachingApp",
    "slug": "coaching-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "coachingapp",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.coachingapp.mobile"
    },
    "android": {
      "package": "com.coachingapp.mobile"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
